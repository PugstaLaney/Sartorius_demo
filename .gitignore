# ─── Python ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ─── .NET / C# ─────────────────────────────────────────────
# Build outputs — regenerated by `dotnet build` / `dotnet run`
[Bb]in/
[Oo]bj/

# Visual Studio state (kept out in case anyone ever opens the project there)
.vs/
*.user
*.suo

# ─── Editor / IDE ──────────────────────────────────────────
# VS Code workspace state (settings we don't want to publish).
# If you decide to commit shared settings, remove this line.
.vscode/

# JetBrains
.idea/

# ─── Environment ───────────────────────────────────────────
.env
*.log

# ─── Generated / runtime data ─────────────────────────────
# The three folders the file-drop pipeline uses at runtime.
# We keep the folders in the repo (via .gitkeep) but ignore contents.
data/incoming/*
!data/incoming/.gitkeep
data/outgoing/*
!data/outgoing/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Time-lapse outputs from dev_scripts (regenerated on demand)
data/timelapse/

# Downloaded LIVECell samples, if someone runs the (currently-absent)
# real-data downloader in the future.
data/livecell_sample/

# Model weights get downloaded on first Cellpose run to a user cache;
# nothing to ignore in the repo for that.

# ─── OS junk ───────────────────────────────────────────────
Thumbs.db
.DS_Store
