<!--
    Cell Segmentation Console - WPF UI.

    This XAML file defines the LAYOUT of the window. C# in MainWindow.xaml.cs
    wires up the behavior (drag-drop, HTTP calls, displaying results).

    Layout map:
      Row 0: Top status bar (backend reachable? device? latency?)
      Row 1: Two-panel image area (original | overlay)
      Row 2: Summary stats strip
      Row 3: Per-cell DataGrid showing morphology
      Row 4: Bottom action bar (Run button, file path label)
-->
<Window x:Class="SegmentationConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cell Segmentation Console" Height="820" Width="1200"
        Background="#0d1117">

    <Window.Resources>
        <!-- Reusable colors so the look stays consistent across the window. -->
        <SolidColorBrush x:Key="PanelBrush" Color="#161b22"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30363d"/>
        <SolidColorBrush x:Key="TextBrush" Color="#e6edf3"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8b949e"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#58a6ff"/>
        <SolidColorBrush x:Key="OkBrush" Color="#3fb950"/>
        <SolidColorBrush x:Key="ErrBrush" Color="#f85149"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: status bar -->
            <RowDefinition Height="*"/>       <!-- 1: image panels -->
            <RowDefinition Height="Auto"/>   <!-- 2: time-lapse slider (hidden until GIF loaded) -->
            <RowDefinition Height="Auto"/>   <!-- 3: summary strip -->
            <RowDefinition Height="200"/>    <!-- 4: per-cell DataGrid -->
            <RowDefinition Height="Auto"/>   <!-- 5: action bar -->
        </Grid.RowDefinitions>

        <!-- ROW 0: Status bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Cell Segmentation Console"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="999" Padding="10,4" Margin="20,0,8,0">
                <TextBlock x:Name="DeviceBadge" Text="device: checking..."
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="12" Foreground="{StaticResource MutedBrush}"/>
            </Border>
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                <TextBlock x:Name="LatencyBadge" Text="latency: —"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="12" Foreground="{StaticResource MutedBrush}"/>
            </Border>
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="999" Padding="10,4">
                <TextBlock x:Name="CountBadge" Text="cells: —"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="12" Foreground="{StaticResource MutedBrush}"/>
            </Border>
        </StackPanel>

        <!-- ROW 1: Two-panel image area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: drop zone + original image. -->
            <Border Grid.Column="0" Margin="0,0,8,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" AllowDrop="True"
                    DragEnter="DropZone_DragEnter" DragOver="DropZone_DragOver"
                    DragLeave="DropZone_DragLeave" Drop="DropZone_Drop"
                    MouseLeftButtonUp="DropZone_Click"
                    Cursor="Hand">
                <Grid>
                    <TextBlock x:Name="DropZoneHint"
                               Text="Drop image or GIF here, or click to browse"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                    <Image x:Name="OriginalImage" Stretch="Uniform" Margin="8"/>
                </Grid>
            </Border>

            <!-- Right: segmentation overlay. -->
            <Border Grid.Column="1" Margin="8,0,0,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <TextBlock x:Name="OverlayHint"
                               Text="Segmentation overlay will appear here"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                    <Image x:Name="OverlayImage" Stretch="Uniform" Margin="8"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ROW 2: Time-lapse slider (collapsed unless a GIF is loaded) -->
        <Border Grid.Row="2" x:Name="TimelapsePanel" Visibility="Collapsed"
                Margin="0,12,0,0" Padding="12,8"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Frame:" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                           Margin="0,0,12,0"/>
                <Slider Grid.Column="1" x:Name="FrameSlider"
                        Minimum="0" Maximum="0" Value="0"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        TickPlacement="BottomRight"
                        Foreground="{StaticResource AccentBrush}"
                        ValueChanged="FrameSlider_ValueChanged"/>
                <TextBlock Grid.Column="2" x:Name="FrameCounter" Text="0 / 0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextBrush}"
                           FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                           Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- ROW 3: Summary strip -->
        <Border Grid.Row="3" Margin="0,12,0,12" Padding="12,8"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6">
            <TextBlock x:Name="SummaryText"
                       Text="No image segmented yet."
                       Foreground="{StaticResource MutedBrush}"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="12"/>
        </Border>

        <!-- ROW 4: Per-cell DataGrid -->
        <DataGrid Grid.Row="4" x:Name="CellGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  Background="{StaticResource PanelBrush}"
                  Foreground="{StaticResource TextBrush}"
                  RowBackground="{StaticResource PanelBrush}"
                  AlternatingRowBackground="#1c2128"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  CanUserAddRows="False" FontFamily="Cascadia Code, Consolas, monospace"
                  FontSize="11">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#21262d"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="track_id" Binding="{Binding TrackId}" Width="80"/>
                <DataGridTextColumn Header="cell_id" Binding="{Binding CellId}" Width="80"/>
                <DataGridTextColumn Header="area_px" Binding="{Binding AreaPx}" Width="100"/>
                <DataGridTextColumn Header="perimeter_px" Binding="{Binding PerimeterPx}" Width="120"/>
                <DataGridTextColumn Header="eccentricity" Binding="{Binding Eccentricity}" Width="120"/>
                <DataGridTextColumn Header="solidity" Binding="{Binding Solidity}" Width="100"/>
                <DataGridTextColumn Header="centroid_y" Binding="{Binding CentroidY}" Width="100"/>
                <DataGridTextColumn Header="centroid_x" Binding="{Binding CentroidX}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ROW 5: Action bar -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FilePathLabel" Grid.Column="0"
                       Text="No file loaded."
                       Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center"
                       FontFamily="Cascadia Code, Consolas, monospace" FontSize="11"/>
            <Button x:Name="RunButton" Grid.Column="1"
                    Content="Run segmentation" Padding="16,8"
                    Background="{StaticResource AccentBrush}" Foreground="#0d1117"
                    BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                    IsEnabled="False" Click="RunButton_Click"/>
        </Grid>
    </Grid>
</Window>
